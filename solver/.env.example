# =============================================================================
# FreeFlo Solver Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For full setup instructions, see: docs/SOLVER_ONBOARDING.md
# =============================================================================

# =============================================================================
# REQUIRED: Blockchain Configuration
# =============================================================================

# RPC URL for Base Sepolia (testnet) or Base Mainnet (production)
# Get a free endpoint from: https://www.alchemy.com/ or https://www.infura.io/
RPC_URL=https://base-sepolia-rpc.publicnode.com

# Chain ID
# - 84532 = Base Sepolia (testnet)
# - 8453  = Base Mainnet (production)
CHAIN_ID=84532

# =============================================================================
# REQUIRED: Contract Addresses
# =============================================================================
# These are the deployed contract addresses. Use the testnet addresses below
# for testing, or deploy your own contracts.

# OffRamp V3 contract (handles intents, quotes, fulfillment)
OFFRAMP_V3_ADDRESS=0x34249F4AB741F0661A38651A08213DDe1469b60f

# Payment Verifier contract (EIP-712 signature verification)
PAYMENT_VERIFIER_ADDRESS=0xd72ddbFAfFc390947CB6fE26afCA8b054abF21fe

# Legacy V2 address (required for config, can use V3 address)
OFFRAMP_V2_ADDRESS=0x34249F4AB741F0661A38651A08213DDe1469b60f

# =============================================================================
# REQUIRED: Solver Wallet
# =============================================================================
# Your solver's private key. This wallet will:
# - Submit quotes on-chain
# - Execute fulfillment transactions
# - Pay gas fees
#
# IMPORTANT:
# 1. Must have ETH for gas (get testnet ETH from https://www.alchemy.com/faucets/base-sepolia)
# 2. Must be authorized on OffRampV3 contract (see docs/SOLVER_ONBOARDING.md)

SOLVER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# =============================================================================
# REQUIRED: Qonto Provider (SEPA Instant - EUR)
# =============================================================================
# Qonto is currently the only supported provider.
# You need a Qonto Business account: https://qonto.com/
#
# For OAuth setup, see: docs/SOLVER_ONBOARDING.md#qonto-oauth-setup

QONTO_ENABLED=true

# Auth method: "oauth" (recommended) or "api_key"
QONTO_AUTH_METHOD=oauth

# OAuth credentials (get from Qonto Partner Portal)
QONTO_ACCESS_TOKEN=ory_at_...
QONTO_REFRESH_TOKEN=ory_rt_...
QONTO_CLIENT_ID=your_client_id
QONTO_CLIENT_SECRET=your_client_secret

# Your Qonto bank account ID (UUID format)
# Find this in Qonto dashboard or via API
QONTO_BANK_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Fee in basis points (100 bps = 1%)
# This is your profit margin on each transaction
QONTO_FEE_BPS=50

# =============================================================================
# REQUIRED: Attestation Service
# =============================================================================
# The attestation service verifies TLSNotary proofs and signs EIP-712 attestations.
# You must run this service alongside the solver.
#
# IMPORTANT: Use 127.0.0.1, NOT localhost (IPv6 issues)

ATTESTATION_ENABLED=true
ATTESTATION_SERVICE_URL=http://127.0.0.1:4001
ATTESTATION_TIMEOUT=30000

# =============================================================================
# REQUIRED: TLSNotary Prover
# =============================================================================
# The prover generates TLSNotary proofs by querying the Qonto API.
# Requires TLSNotary to be built locally.
#
# See: docs/SOLVER_ONBOARDING.md#tlsnotary-setup

PROVER_ENABLED=true

# Path to TLSNotary examples directory (where Qonto prover is built)
TLSN_EXAMPLES_PATH=/opt/tlsn/crates/examples

# Where to store generated proofs
PROOF_STORAGE_PATH=./proofs

# Prover timeout in ms (5 min recommended - first run compiles Rust)
PROVER_TIMEOUT=300000

# API Key credentials for TLSNotary prover (different from OAuth!)
# These are used by the prover to query Qonto API via TLS
QONTO_API_KEY_LOGIN=your-org-slug
QONTO_API_KEY_SECRET=your_api_key_secret
QONTO_BANK_ACCOUNT_SLUG=your-org-slug-bank-account-1

# =============================================================================
# OPTIONAL: Server Ports
# =============================================================================

# Health check endpoint port (GET /health, /ready, /live)
HEALTH_PORT=8080

# Quote API port (GET /api/quote?amount=100&currency=EUR)
QUOTE_API_PORT=8081

# =============================================================================
# OPTIONAL: Orchestrator Settings
# =============================================================================

# How often to poll for new intents (milliseconds)
POLL_INTERVAL=5000

# Minimum USDC amount to process (6 decimals, so 1000000 = 1 USDC)
MIN_USDC_AMOUNT=1000000

# Maximum USDC amount to process (6 decimals, so 10000000000 = 10,000 USDC)
MAX_USDC_AMOUNT=10000000000

# =============================================================================
# OPTIONAL: Database
# =============================================================================

# SQLite database path for tracking intents and quotes
DB_PATH=./solver.db

# =============================================================================
# OPTIONAL: Logging
# =============================================================================

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# OPTIONAL: Sandbox/Testing
# =============================================================================

# Use Qonto sandbox environment (for testing without real money)
QONTO_USE_SANDBOX=false

# Staging token (required for sandbox)
QONTO_STAGING_TOKEN=

# Fixed USDC/EUR rate (for testing - omit to use live CoinGecko rate)
# QONTO_USDC_EUR_RATE=0.92
